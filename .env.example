# Porta usada para acessar a aplicação no computador do cliente
APP_PORT=8000

# Gere um valor longo e aleatório antes de instalar no cliente
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Administrador criado somente na primeira inicialização
ADMIN_EMAIL=admin@sistema.com
ADMIN_PASSWORD=troque-por-uma-senha-temporaria-com-12-caracteres

# Banco PostgreSQL criado pelo Docker Compose
POSTGRES_DB=estoque
POSTGRES_USER=estoque
POSTGRES_PASSWORD=troque-por-uma-senha-forte

# Porta local do PostgreSQL. Altere se a porta 5432 já estiver em uso.
POSTGRES_PORT=5432

# Backup automático do PostgreSQL
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# DATABASE_URL é opcional e usada apenas ao executar sem Docker.
# Quando vazia e fora do Docker, a aplicação usa SQLite local.
DATABASE_URL=
